{
  "General": {
    "Cycle through open windows": "Alt + Tab"
  }
  "Windows": {
    "Close window": "Alt + Escape"
  }
  "System": {
    "Log out": "Ctrl + Alt + Delete",
    "Shut down": "Ctrl + Alt + End",
    "Lock screen": [
      "Ctrl + Alt + L",
      "Alt + S"
    ]
  },
  "Launchers": {
    "Launch terminal": "Alt + Return"
  },
  "Sound and Media": {
    "Play": "Shift + Ctrl + K",
    "Previous track": "Shift + Ctrl + J",
    "Next track": "Shift + Ctrl + L"
  },
  "Universal Access": {
    "Turn screen read on or off": "Alt + Super + S"
  }
}
