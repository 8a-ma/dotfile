# =============================================================================
# .gitignore — Dotfiles i3
# =============================================================================

# Archivos de caché y temporales
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Directorios de caché generados en runtime
.config/*/cache/
.config/*/__pycache__/
**/__pycache__/
*.pyc

# Logs
*.log
/tmp/

# Archivos sensibles — NUNCA commitear
.config/*/secrets
.config/*/credentials
*passwd*
*token*
*api_key*
.ssh/

# Eww — compilados temporales
.config/eww/target/

# Nitrogen — rutas absolutas de wallpaper (cambian por máquina)
.config/nitrogen/bg-saved.cfg

# Temas GTK generados automáticamente
.config/gtk-3.0/bookmarks
.config/gtk-4.0/

# arandr — configs generadas (cada máquina tiene sus propios nombres de salida)
# EXCEPCIÓN: puedes versionar los .sh que generes manualmente
.config/autorandr/

# Archivos específicos del sistema local
.config/mimeapps.list
.config/user-dirs.dirs
.config/user-dirs.locale